# Required: PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/red_db

# Optional: Flask configuration
FLASK_DEBUG=false
PORT=5000

# Optional: Override the Flask secret key (defaults to encryption key)
# FLASK_SECRET_KEY=your-secret-key

# Optional: Override JWT secret (defaults to Flask secret key)
# JWT_SECRET_KEY=your-jwt-secret
